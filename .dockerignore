# Build outputs
build/
out/
**/CMakeFiles/
**/CMakeCache.txt
**/cmake_install.cmake
**/CTestTestfile.cmake

# IDE
.vs/
.vscode/
.idea/
*.user
*.suo

# Qt generated
*_autogen/
moc_*.cpp
ui_*.h
qrc_*.cpp

# Compiled binaries
*.exe
*.dll
*.lib
*.pdb
*.obj
*.o

# Logs
*.log
logs/
build_log*.txt

# Models (montés en volume au runtime)
models/*.onnx
models/*.engine
models/*.trt

# Git (inutile dans le container)
.git/
.gitignore
.gitattributes

# Claude / outils
.claude/

# OS
Thumbs.db
.DS_Store
Desktop.ini

# Docker (éviter récursion)
docker/
.dockerignore

# Documentation (pas nécessaire pour build)
docs/
*.md
README.md

# vcpkg local
build/vcpkg_installed/

# Cache TensorRT (regénéré au runtime)
tensorrt-cache/

# Données runtime persistées (montées en volume, hors contexte de build)
data/

# -----------------------------------------------------------------------------
# Exceptions : runtime.Dockerfile COPYe ces chemins depuis le contexte de build.
# Sans ces "un-ignore", `docker compose build runtime` echoue (COPY not found)
# car build/ et docker/ sont exclus plus haut. Le binaire doit avoir ete compile
# dans le container dev au prealable (bash scripts/build_jetson.sh).
# -----------------------------------------------------------------------------
!build/bin
!build/bin/MicroscopeIBOM
!docker/entrypoint.sh
